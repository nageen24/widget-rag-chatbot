{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/frontend/$1" },
    { "src": "/(chat|health|ingest)(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/frontend/index.html" }
  ]
}
